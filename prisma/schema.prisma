generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String?           @unique
  phone              String?           @unique
  name               String?
  image              String?
  registrationNumber String?           @unique
  studentPhoto       String?
  role               Role              @default(USER)
  isVerified         Boolean           @default(false)
  isProfileCompleted Boolean           @default(false)
  collegeIdUrl       String?
  trustScore         Int               @default(50)
  address            String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  banReason          String?
  fraudScore         Int               @default(0)
  isSuspended        Boolean           @default(false)
  isTrustedSeller    Boolean           @default(false)
  lastActive         DateTime?         @default(now())
  verificationLevel  VerificationLevel @default(BASIC)
  activityLogs       ActivityLog[]
  buyingRequests     BuyingRequest[]
  cart               Cart?
  exchangeOffers     ExchangeOffer[]
  messagesRecv       Message[]         @relation("Receiver")
  messagesSent       Message[]         @relation("Sender")
  notifications      Notification[]
  orders             Order[]
  payments           Payment[]
  products           Product[]
  profile            Profile?
  quoteRequests      QuoteRequest[]
  rentalsOwned       Rental[]          @relation("Owner")
  rentals            Rental[]          @relation("Renter")
  reportsRecv        Report[]          @relation("Reported")
  reportsMade        Report[]          @relation("Reporter")
  subscription       Subscription?
  activities         UserActivity[]
  wishlist           Wishlist[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  collegeName     String?
  course          String?
  year            String?
  batch           String?
  hostel          String?
  bio             String?
  rating          Float    @default(0)
  successfulDeals Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  avgResponseTime Int?
  businessType    String?
  successRate     Float    @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Country {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  states    State[]
}

model State {
  id        String   @id @default(cuid())
  name      String
  slug      String
  countryId String
  createdAt DateTime @default(now())
  cities    City[]
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([name, countryId])
}

model City {
  id        String   @id @default(cuid())
  name      String
  slug      String
  stateId   String
  createdAt DateTime @default(now())
  campuses  Campus[]
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([name, stateId])
}

model Campus {
  id        String    @id @default(cuid())
  name      String
  slug      String
  cityId    String
  createdAt DateTime  @default(now())
  city      City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, cityId])
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  icon          String?
  createdAt     DateTime      @default(now())
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  slug       String
  categoryId String
  createdAt  DateTime  @default(now())
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([name, categoryId])
}

model Product {
  id                  String          @id @default(cuid())
  title               String
  description         String
  price               Float
  originalPrice       Float?
  brand               String?
  purchaseYear        Int?
  isNegotiable        Boolean         @default(false)
  condition           Condition       @default(GOOD)
  conditionDetails    Json?
  listingType         ListingType     @default(SELL)
  images              String[]
  pickupLocation      String
  status              ProductStatus   @default(PENDING)
  isUrgent            Boolean         @default(false)
  views               Int             @default(0)
  wishlistCount       Int             @default(0)
  sellerId            String
  categoryId          String
  subcategoryId       String?
  campusId            String
  customSubcategory   String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  fraudScore          Int             @default(0)
  isSuspicious        Boolean         @default(false)
  moderationReason    String?
  exchangeCashAllowed Boolean         @default(false)
  exchangeCategories  String[]        @default([])
  isExchangeAllowed   Boolean         @default(false)
  inventory           Int             @default(1)
  cartItems           CartItem[]
  exchangeOffers      ExchangeOffer[]
  boosts              ListingBoost[]
  offers              Offer[]
  orderItems          OrderItem[]
  campus              Campus          @relation(fields: [campusId], references: [id])
  category            Category        @relation(fields: [categoryId], references: [id])
  seller              User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  subcategory         Subcategory?    @relation(fields: [subcategoryId], references: [id])
  rentals             Rental[]
  rentalDetail        RentalDetail?
  reports             Report[]
  serviceDetail       ServiceDetail?
  wishlistedBy        Wishlist[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([campusId])
  @@index([createdAt])
  @@index([title])
  @@index([status, createdAt])
  @@index([status, price])
  @@index([status, categoryId, createdAt])
  @@index([status, listingType, createdAt])
}

model AiRule {
  id        String   @id @default(cuid())
  name      String
  rule      Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id         String   @id @default(cuid())
  content    String
  imageUrl   String?
  isRead     Boolean  @default(false)
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id                String   @id @default(cuid())
  userId            String
  productId         String
  createdAt         DateTime @default(now())
  lastNotifiedPrice Float?
  priceAtWishlist   Float?
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  guestId   String?    @unique
  subtotal  Float      @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([guestId])
}

model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  productId     String
  quantity      Int      @default(1)
  priceSnapshot Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([productId])
}

model BuyingRequest {
  id          String      @id @default(cuid())
  title       String
  description String
  budget      Float?
  category    String?
  listingType ListingType @default(SELL)
  userId      String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Offer {
  id        String      @id @default(cuid())
  price     Float
  status    OfferStatus @default(PENDING)
  message   String?
  buyerId   String
  productId String
  createdAt DateTime    @default(now())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Report {
  id          String       @id @default(cuid())
  reason      ReportReason
  description String?
  status      ReportStatus @default(PENDING)
  reporterId  String
  reportedId  String?
  productId   String?
  createdAt   DateTime     @default(now())
  product     Product?     @relation(fields: [productId], references: [id])
  reported    User?        @relation("Reported", fields: [reportedId], references: [id])
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
}

model Ad {
  id          String      @id @default(cuid())
  title       String
  imageUrl    String
  linkUrl     String
  sponsorName String
  placement   AdPlacement @default(HOMEPAGE)
  isActive    Boolean     @default(true)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime    @default(now())
}

model RentalDetail {
  id              String   @id @default(cuid())
  productId       String   @unique
  securityDeposit Float    @default(0)
  minDuration     Int      @default(1)
  maxDuration     Int?
  availability    Json?
  terms           String?
  rentals         Rental[]
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Rental {
  id                String       @id @default(cuid())
  productId         String
  renterId          String
  ownerId           String
  rentalDetailId    String
  startDate         DateTime
  endDate           DateTime
  securityDeposit   Float
  pickupLocation    String
  status            RentalStatus @default(PENDING)
  paymentId         String?
  agreementAccepted Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  owner             User         @relation("Owner", fields: [ownerId], references: [id])
  product           Product      @relation(fields: [productId], references: [id])
  rentalDetail      RentalDetail @relation(fields: [rentalDetailId], references: [id])
  renter            User         @relation("Renter", fields: [renterId], references: [id])

  @@index([productId])
  @@index([renterId])
  @@index([ownerId])
}

model ServiceDetail {
  id             String         @id @default(cuid())
  productId      String         @unique
  hourlyRate     Float?
  experience     String?
  availability   String?
  qualifications String?
  portfolio      String[]
  quoteRequests  QuoteRequest[]
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model QuoteRequest {
  id              String        @id @default(cuid())
  serviceDetailId String
  userId          String
  content         String
  status          QuoteStatus   @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  serviceDetail   ServiceDetail @relation(fields: [serviceDetailId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  content   String
  link      String?
  isRead    Boolean          @default(false)
  userId    String
  createdAt DateTime         @default(now())
  type      NotificationType
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  startDate       DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  autoRenew       Boolean            @default(false)
  expiryDate      DateTime?
  paymentId       String?
  planType        PlanType           @default(FREE)
  razorpayOrderId String?            @unique
  status          SubscriptionStatus @default(PENDING)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  subscriptionId  String?
  gateway         PaymentGateway @default(RAZORPAY)
  amount          Float
  currency        String         @default("INR")
  paymentStatus   PaymentStatus  @default(PENDING)
  transactionId   String?        @unique
  razorpayOrderId String?        @unique
  webhookPayload  Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  order           Order?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  paymentId       String?     @unique
  status          OrderStatus @default(PENDING)
  total           Float
  shippingAddress Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  payment         Payment?    @relation(fields: [paymentId], references: [id])
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  priceAtPurchase Float
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])

  @@unique([orderId, productId])
  @@index([productId])
}

model ListingBoost {
  id            String      @id @default(cuid())
  productId     String
  startDate     DateTime    @default(now())
  endDate       DateTime
  boostType     BoostType
  createdAt     DateTime    @default(now())
  paymentId     String?
  priorityScore Int         @default(1)
  sellerId      String
  status        BoostStatus @default(PENDING)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sellerId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  type      String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String?
  productId    String?
  rentalId     String?
  paymentId    String?
  actionType   String
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
}

model TransactionRecord {
  id        String            @id @default(cuid())
  buyerId   String
  sellerId  String
  productId String?
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  metadata  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([buyerId])
  @@index([sellerId])
}

model ExchangeOffer {
  id                 String         @id @default(cuid())
  productId          String
  buyerId            String
  offeredTitle       String
  offeredDescription String
  offeredImages      String[]
  cashDifference     Float?
  status             ExchangeStatus @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  buyer              User           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  product            Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([buyerId])
}

enum VerificationLevel {
  BASIC
  VERIFIED
  BUSINESS
  CAMPUS
}

enum Role {
  USER
  ADMIN
  VENDOR
}

enum ListingType {
  SELL
  RENT
  SERVICE
}

enum Condition {
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ProductStatus {
  PENDING
  LIVE
  REJECTED
  SOLD
  ARCHIVED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ReportReason {
  FAKE_LISTING
  SPAM
  ABUSIVE_CONTENT
  WRONG_INFORMATION
  SCAM
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

enum AdPlacement {
  HOMEPAGE
  CATEGORY
  SEARCH
}

enum RentalStatus {
  PENDING
  ACTIVE
  RETURNED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  REPLIED
  CANCELLED
}

enum NotificationType {
  MESSAGE
  OFFER
  SYSTEM
  RENTAL_REQUEST
  RENTAL_APPROVED
  RENTAL_REMINDER
  SERVICE_QUOTE
  PAYMENT_SUCCESS
  SUBSCRIPTION_EXPIRY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PlanType {
  FREE
  PRO_SELLER
  CAMPUS_BUSINESS
}

enum PaymentGateway {
  RAZORPAY
  PAYTM
  STRIPE
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
  REFUNDED
}

enum BoostType {
  THREE_DAY
  SEVEN_DAY
  THIRTY_DAY
}

enum BoostStatus {
  ACTIVE
  EXPIRED
  PENDING
}

enum TransactionType {
  SALE
  RENT
  SERVICE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  NO_RESPONSE
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  COMPLETED
}
